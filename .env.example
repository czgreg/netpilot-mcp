# NetPilot-MCP 默认凭证配置（环境变量）
# 复制此文件为 .env 并填写实际凭证

# 默认登录用户名
NETPILOT_USERNAME=admin

# 默认登录密码
NETPILOT_PASSWORD=

# Enable/特权模式密码（可选）
NETPILOT_ENABLE_PASSWORD=

# SSH host key 严格校验（默认 true）
NETPILOT_SSH_STRICT_HOST_KEY=true

# 自定义 known_hosts 文件路径（可选）
# NETPILOT_KNOWN_HOSTS_FILE=/Users/you/.ssh/known_hosts

# 是否允许 Telnet（默认 true）
NETPILOT_ALLOW_TELNET=true

# 安全规则配置文件路径（可选）
# NETPILOT_SECURITY_RULES=/path/to/security_rules.json
